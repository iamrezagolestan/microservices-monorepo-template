# Local inner-loop environment for `orders` (ADR-0003, ADR-0016).
# Copy to .env — `mise run server` / `mise run worker` and your IDE's debugger pick it up.
#
# Prereqs (cluster + deps, then port-forward them to localhost):
#   mise run cluster:lite    # once: k3d cluster + deps
#   mise run dev:forward     # separate terminal, leave running
#   mise run db:migrate      # once per schema change

# Port-forwarded local Postgres (see infra/local/deps.yaml).
DATABASE_URL=postgres://dev:dev@localhost:5432/orders?sslmode=disable

# SpiceDB (libs/go/authz) — dialed lazily, but the key is required at startup.
# The lite deps run an in-memory SpiceDB with a fixed dev preshared key.
SPICEDB_ENDPOINT=localhost:50051
SPICEDB_PRESHARED_KEY=dev

# Temporal (libs/go/temporalmw) — required by `mise run worker`, which runs the
# checkout saga (ADR-0006).
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default

# The checkout saga calls catalog and payment over HTTP. Both default to in-cluster
# DNS, which a natively-run worker cannot resolve — so either deploy those two into
# the cluster (`mise run service:deploy -- catalog`) and port-forward them, or run one
# natively and point at it here. Every server hardcodes :8080, so only one at a time
# can run natively on the host.
# CATALOG_URL=http://localhost:8080
# PAYMENT_URL=http://localhost:8080

# Uncomment when running an OTel collector locally (none ships in the lite deps).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
