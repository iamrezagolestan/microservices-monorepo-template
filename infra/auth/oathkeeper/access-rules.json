[
  {
    "id": "api-services",
    "match": { "url": "<{http,https}>://<**>/api/<{products,orders,orgs,charges,observability}><**>", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
    "authenticators": [{ "handler": "cookie_session" }, { "handler": "jwt" }, { "handler": "anonymous" }],
    "authorizer": { "handler": "allow" },
    "mutators": [{ "handler": "header" }],
    "errors": [{ "handler": "json" }]
  },
  {
    "id": "ops-lowdefy",
    "match": { "url": "<{http,https}>://lowdefy.ops.<**>/<**>", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
    "authenticators": [{ "handler": "cookie_session" }],
    "authorizer": { "handler": "remote_json", "config": { "remote": "http://authz-server.platform.svc.cluster.local/authorize", "payload": "{\"subject\":\"{{ print .Subject }}\",\"tool\":\"lowdefy\",\"aal\":\"{{ print .Extra.authenticator_assurance_level }}\",\"operator\":\"{{ print .Extra.identity.traits.operator }}\"}" } },
    "mutators": [{ "handler": "header", "config": { "headers": { "X-User-Id": "{{ print .Subject }}", "X-User-Email": "{{ print .Extra.identity.traits.email }}" } } }],
    "errors": [{ "handler": "redirect" }]
  },
