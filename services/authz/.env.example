# Local inner-loop environment for `authz` (ADR-0003, ADR-0016, ADR-0017).
# Copy to .env — `mise run run` and your IDE's debugger pick it up.
#
# authz is the ops-tier edge authorizer: no database, no worker. It needs SpiceDB,
# and Kratos only for the identity-listing endpoints.
#
# Prereqs:
#   mise run cluster:lite    # once: k3d cluster + deps
#   mise run dev:forward     # separate terminal, leave running

# SpiceDB (libs/go/authz) — dialed lazily, but the key is required at startup.
# The lite deps run an in-memory SpiceDB with a fixed dev preshared key.
SPICEDB_ENDPOINT=localhost:50051
SPICEDB_PRESHARED_KEY=dev

# Kratos identity admin API, behind the /identities endpoints the admin console's
# Users page calls. Kratos is NOT in the lite deps — only the full tier runs it
# (`mise run cluster:full`), so port-forward it there before uncommenting:
#   kubectl -n platform port-forward svc/ory-kratos-admin 4434:80
# KRATOS_ADMIN_URL=http://localhost:4434

# Optional fine per-tool SpiceDB layer on top of the always-on coarse claim gate
# (ADR-0017). Default off keeps the coarse gate free of any SpiceDB dependency.
# OPS_FINE_GRAINED=true

# Uncomment when running an OTel collector locally (none ships in the lite deps).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
