# Editors
.idea/
*.iml
.run/
.vscode/
.history
*~
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env files (ADR-0005: never commit real secrets; encrypted .enc.yaml is ok)
.env
.env.*
!.env.example

# Go
/bin/
/dist/
*.test
*.out
coverage.*

# Node / Bun
node_modules/
.next/
out/
.bun/
*.tsbuildinfo

# Biome (ADR-0014)
.biome/

# Playwright e2e (ADR-0014, ADR-0018)
playwright-report/
test-results/
blob-report/
# Saved auth storage states (session cookies) from the e2e setup project.
e2e/.auth/

# Helm / Terraform
**/charts/*.tgz
# ...except the observability subcharts, which are vendored into git so ArgoCD's
# repo-server renders them offline (no `helm dependency build` / network, which
# wedges behind the local privoxy edge). See observability/Chart.yaml.
!infra/helm/platform/observability/charts/*.tgz
# ...and the Coroot operator subchart, vendored for the same offline reason.
!infra/helm/platform/coroot/charts/*.tgz
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# Local k3d state
.k3d/

# Mise local cache
.mise.local.toml

# Rumble cache
.rumdl_cache
