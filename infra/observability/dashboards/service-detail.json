{
  "title": "Service detail",
  "uid": "service-detail",
  "schemaVersion": 39,
  "tags": ["service", "detail", "poc"],
  "description": "POC (see docs): the 'click a service, see everything' unified page. One templated dashboard scoped by $service, mixing Prometheus + Loki + Tempo + Pyroscope on one screen: SLO (availability + latency + error budget), RED, CPU/Memory (kubeletstats), Logs, Traces, and a CPU flame graph (Alloy → Pyroscope). All six signal groups are wired on the full-tier stack.",
  "links": [
    {
      "title": "◀ Back to Applications",
      "type": "link",
      "url": "/d/applications/applications?${__url_time_range}",
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_server_request_duration_seconds_count, service_name)"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "SLO (over the selected time range)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Availability",
      "description": "Share of non-5xx requests over the dashboard time range. Target 99.9%.",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 99,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.9 },
              { "color": "green", "value": 99.95 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - ((sum(rate(http_server_request_duration_seconds_count{service_name=\"$service\",http_response_status_code=~\"5..\"}[$__range])) or vector(0)) / sum(rate(http_server_request_duration_seconds_count{service_name=\"$service\"}[$__range]))))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Latency SLO — % faster than 500ms",
      "description": "Share of requests served under the 500ms latency objective (le=\"0.5\" on the stable OTel http.server.request.duration histogram, real seconds). Target 99%.",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 90,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_server_request_duration_seconds_bucket{service_name=\"$service\",le=\"0.5\"}[$__range])) or vector(0)) / sum(rate(http_server_request_duration_seconds_count{service_name=\"$service\"}[$__range]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error budget remaining (99.9% target)",
      "description": "How much of the 0.1% error budget is left over the range. Negative means the availability SLO is already burned through.",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (((sum(rate(http_server_request_duration_seconds_count{service_name=\"$service\",http_response_status_code=~\"5..\"}[$__range])) or vector(0)) / sum(rate(http_server_request_duration_seconds_count{service_name=\"$service\"}[$__range]))) / 0.001))"
        }
      ]
    },

    {
      "type": "row",
      "title": "Golden signals (RED)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "Request rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{service_name=\"$service\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 7 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } }
      },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{service_name=\"$service\",http_response_status_code=~\"5..\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "p50",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"$service\"}[5m])))"
        },
        {
          "refId": "p95",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"$service\"}[5m])))"
        },
        {
          "refId": "p99",
          "legendFormat": "p99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"$service\"}[5m])))"
        }
      ]
    },

    {
      "type": "row",
      "title": "Resources (CPU / Memory)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "type": "timeseries",
      "title": "CPU usage (cores)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        {
          "legendFormat": "{{service_name}}",
          "expr": "sum by (service_name) (k8s_pod_cpu_usage{service_namespace=\"platform\",service_name=\"$service\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory usage",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "legendFormat": "{{service_name}}",
          "expr": "sum by (service_name) (k8s_pod_memory_usage_bytes{service_namespace=\"platform\",service_name=\"$service\"})"
        }
      ]
    },

    { "type": "row", "title": "Logs (Loki)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 } },
    {
      "type": "logs",
      "title": "Recent logs",
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [{ "expr": "{service_name=\"$service\"}" }]
    },

    { "type": "row", "title": "Traces (Tempo)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 } },
    {
      "type": "table",
      "title": "Recent traces — click a traceID to open the flame graph",
      "datasource": "Tempo",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ resource.service.name=\"$service\" }",
          "tableType": "traces",
          "limit": 20
        }
      ]
    },

    {
      "type": "row",
      "title": "Profiling (Pyroscope)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 }
    },
    {
      "type": "flamegraph",
      "title": "CPU profile — scraped from the service's pprof endpoint by Alloy",
      "datasource": "Pyroscope",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 47 },
      "targets": [
        {
          "refId": "A",
          "queryType": "profile",
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service_name=\"$service\"}"
        }
      ]
    }
  ]
}
